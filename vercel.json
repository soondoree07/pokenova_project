{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pokenova.vercel.app" }],
      "destination": "https://pokenova.pochams.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/pokedex", "destination": "/pokedex.html" },
    { "source": "/movedex", "destination": "/movedex.html" },
    { "source": "/itemdex", "destination": "/itemdex.html" },
    { "source": "/entry", "destination": "/entry.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/record", "destination": "/record.html" }
  ]
}
